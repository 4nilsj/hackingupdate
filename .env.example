# ─── Required ──────────────────────────────────────────────────────────────────
# LLM API key for threat ranking (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=google/gemini-2.5-flash:free

# ─── Microsoft Teams (optional) ───────────────────────────────────────────────
TEAMS_WEBHOOK_URL=

# ─── WhatsApp via Generic API (optional) ──────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_TOKEN=
WHATSAPP_RECIPIENT=

# ─── WhatsApp via Twilio (optional) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=whatsapp:+14155238886
TWILIO_TO_NUMBER=

# ─── Email / SMTP (optional) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_TO_EMAILS=secops@company.com,team@company.com
SMTP_USE_TLS=true

# ─── Pipeline Tuning ──────────────────────────────────────────────────────────
ARTICLE_MAX_AGE_DAYS=1
LLM_BATCH_DELAY=2.0

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text  # Options: text, json
